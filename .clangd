CompileFlags:
  CompilationDatabase: build/

Diagnostics:
  ClangTidy:
    Add:
      - bugprone-*
      - clang-analyzer-core.*
      - clang-analyzer-unix.*
      - misc-*
      - readability-identifier-naming
      - readability-function-cognitive-complexity
      - performance-*
    Remove:
      - misc-no-recursion
      - misc-static-assert
  UnusedIncludes: Strict
  MissingIncludes: Strict
